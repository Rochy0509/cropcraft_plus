    def Scope "_materials"
    {
        def Material "tomato" (
            prepend apiSchemas = ["ColorSpaceAPI"]
        )
        {
            uniform token colorSpace:name = "lin_rec709_scene"
            token outputs:displacement.connect = </root/_materials/tomato/Principled_BSDF.outputs:displacement>
            token outputs:surface.connect = </root/_materials/tomato/Principled_BSDF.outputs:surface>
            custom string userProperties:blender:data_name = "tomato"

            def Shader "Principled_BSDF"
            {
                uniform token info:id = "UsdPreviewSurface"
                float inputs:clearcoat = 0
                float inputs:clearcoatRoughness = 0.03
                color3f inputs:diffuseColor.connect = </root/_materials/tomato/Image_Texture.outputs:rgb>
                float inputs:displacement.connect = </root/_materials/tomato/Image_Texture_003.outputs:b>
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:ior = 1.5
                float inputs:metallic.connect = </root/_materials/tomato/Image_Texture_003.outputs:r>
                normal3f inputs:normal.connect = </root/_materials/tomato/Image_Texture_002.outputs:rgb>
                float inputs:opacity = 1
                float inputs:roughness.connect = </root/_materials/tomato/Image_Texture_003.outputs:g>
                float inputs:specular.connect = </root/_materials/tomato/Image_Texture_001.outputs:r>
                token outputs:displacement
                token outputs:surface
            }

            def Shader "Image_Texture" (
                prepend apiSchemas = ["ColorSpaceAPI"]
            )
            {
                uniform token colorSpace:name = "srgb_rec709_display"
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/tomato2_BaseColor.tga@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/tomato/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "uvmap"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }

            def Shader "Image_Texture_003" (
                prepend apiSchemas = ["ColorSpaceAPI"]
            )
            {
                uniform token colorSpace:name = "srgb_rec709_display"
                uniform token info:id = "UsdUVTexture"
                float4 inputs:bias = (-0.005, -0.005, -0.005, 0)
                asset inputs:file = @./textures/tomato2_HDRP_mask.tga@
                float4 inputs:scale = (0.01, 0.01, 0.01, 1)
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/tomato/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:b
                float outputs:g
                float outputs:r
            }

            def Shader "Image_Texture_002" (
                prepend apiSchemas = ["ColorSpaceAPI"]
            )
            {
                uniform token colorSpace:name = "data"
                uniform token info:id = "UsdUVTexture"
                float4 inputs:bias = (-1, -1, -1, -1)
                asset inputs:file = @./textures/tomato_Normal.tga@
                float4 inputs:scale = (2, 2, 2, 2)
                token inputs:sourceColorSpace = "raw"
                float2 inputs:st.connect = </root/_materials/tomato/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "Image_Texture_001" (
                prepend apiSchemas = ["ColorSpaceAPI"]
            )
            {
                uniform token colorSpace:name = "srgb_rec709_display"
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/tomato2_ARM_mask.tga@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/tomato/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:r
            }
        }
    }

    def DomeLight "env_light" (
        prepend apiSchemas = ["ColorSpaceAPI"]
    )
    {
        uniform token colorSpace:name = "lin_rec709_scene"
        float inputs:intensity = 1
        asset inputs:texture:file = @./textures/color_0C0C0C.exr@
    }
}

